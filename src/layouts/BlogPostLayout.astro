---
import BasicLayout from "./BasicLayout.astro";

interface Props {
  title: string;
  date: Date;
  description: string;
  tags?: string[];
}

const { title, date, description, tags } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BasicLayout title={title}>
  <article class="post">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {tags && tags.length > 0 && (
          <ul class="tags">
            {tags.map(tag => <li class="tag">{tag}</li>)}
          </ul>
        )}
      </div>
      <h1>{title}</h1>
      <p class="description">{description}</p>
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>
</BasicLayout>

<style>
  .post {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 2rem;
    font-family: inherit;
    color: #333;
  }

  .post-header {
    margin-bottom: 2.5rem;
    border-bottom: 1px solid #e5e5e5;
    padding-bottom: 2rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  time {
    font-size: 0.9rem;
    color: #888;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8rem;
    background-color: #e5e5e5;
    color: #555;
    padding: 0.2em 0.7em;
    border-radius: 999px;
  }

  .post-header h1 {
    font-size: 2.4rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .description {
    font-size: 1.1rem;
    color: #666;
    margin: 0;
    line-height: 1.6;
  }

  .post-content {
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .post-content :global(h2) {
    font-size: 1.6rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: #222;
  }

  .post-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 1.5rem 0 0.5rem;
    color: #222;
  }

  .post-content :global(p) {
    margin: 0 0 1.25rem;
    color: #444;
  }

  .post-content :global(a) {
    color: #378a9c;
    text-decoration: underline;
  }

  .post-content :global(code) {
    background-color: #f4f4f4;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .post-content :global(pre) {
    background-color: #1e1e1e;
    color: #d4d4d4;
    padding: 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.9em;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid #378a9c;
    margin: 1.5rem 0;
    padding: 0.5rem 1.25rem;
    background-color: #f0f8fa;
    border-radius: 0 8px 8px 0;
    color: #555;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }

  .post-content :global(img) {
    max-width: 100%;
    border-radius: 8px;
    margin: 1.5rem 0;
  }
</style>
