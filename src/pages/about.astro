---
import BasicLayout from "../layouts/BasicLayout.astro";
---

<BasicLayout title="About">
  <div class="about scroll-container">
    <section class="about-intro snap-section">
      <img src="/about.jpg" alt="Christopher Walker" class="about-intro-photo" />
      <div class="about-intro-text">
        <h1>About Me</h1>
        <p>
          I was born in London. Grew up in the Madison, Wisconsin (USA). Moved to Germany after I finished
          my Bachelor's degree. Came to Zurich thirteen years ago for my Master's degree and  
          have been living here ever since.
        </p>
      </div>
    </section>

    <section class="about-card reverse snap-section" id="engineer">
      <img src="/engineer.jpg" alt="Engineering" />
      <div class="about-card-text">
        <h2>Engineer</h2>
        <p>
          I trained as a mechanical engineer, which gave me a strong foundation in
          systems thinking, precision, and problem solving. Over time I found myself
          drawn deeper into software, and today I work professionally as a software
          developer in the manufacturing industry — bridging the gap between the
          physical and digital worlds. I bring an engineer's mindset to every line
          of code I write.
        </p>
      </div>
    </section>

    <section class="about-card snap-section" id="mountain-enthusiast">
      <img src="/mountains.jpg" alt="Mountains" />
      <div class="about-card-text">
        <h2>Mountain Enthusiast</h2>
        <p>
          I love being out in the mountains. They fill me with energy and joy. In the winter it
          is on skis or snowboard, skinning up in search of the quiet solitude
          and fresh tracks. In the summer it is on a mountain bike searching for
          flowy cross-country trails. I spend a lot of my time in the Surselva
          valley near the Oberalp pass. There's nothing quite like standing on a
          summit after a long climb.
        </p>
      </div>
    </section>

    <section class="about-card reverse snap-section" id="disc-golfer">
      <img src="/discgolf.jpg" alt="Disc golf" />
      <div class="about-card-text">
        <h2>Disc Golfer</h2>
        <p>
          I am very involved in the swiss disc golf community, both playing as well
          as organizing tournaments. I am currently the tournament director for the annually
          swiss tour stop in Zürich, the Zürich Disc Golf Open (ZDGO).
          I am also a member of the Swiss national team.
        </p>
      </div>
    </section>
  </div>
</BasicLayout>

<style>
  .scroll-container {
    scroll-snap-type: y mandatory;
    height: calc(100vh - var(--nav-height, 0px));
    overflow-y: scroll;
  }

  .snap-section {
    max-width: 900px;
    margin: 0 auto;
    scroll-snap-align: start;
    height: calc(100vh - var(--nav-height, 0px));
    width: 100%;
  }

  .about {
    font-family: inherit;
    color: #333;
  }

  .about-intro {
    display: flex;
    flex-direction: row-reverse;
    align-items: center;
    justify-content: center;
    column-gap: 3rem;
    row-gap: 1rem;
    flex-wrap: wrap;
    align-content: center;
  }

  .about-intro-photo {
    width: 300px;
    height: 300px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .about-intro-text {
    max-width: 480px;
  }

  .about-intro-text h1 {
    font-size: 2.8rem;
    font-weight: 400;
    margin: 0 0 1rem;
    color: #333;
  }

  .about-intro-text p {
    font-size: 1.15rem;
    color: #555;
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 600px) {
    .about-intro-photo {
      width: 220px;
      height: 220px;
    }
  }

  .about-card {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
    align-content: center;
    padding: 0 2rem;
  }

  .about-card.reverse {
    flex-direction: row-reverse;
  }

  .about-card img {
    width: 380px;
    height: 260px;
    object-fit: cover;
    border-radius: 12px;
    flex-shrink: 0;
  }

  .about-card-text {
    flex: 1;
    min-width: 260px;
  }

  .about-card-text h2 {
    font-size: 1.6rem;
    font-weight: 500;
    margin: 0 0 0.75rem;
  }

  .about-card-text p {
    font-size: 1.05rem;
    color: #555;
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 650px) {
    .about-card,
    .about-card.reverse {
      flex-direction: column;
    }

    .about-card img {
      width: 100%;
      height: 220px;
    }
  }
</style>

<script>
  const nav = document.querySelector("nav");
  if (nav) {
    document.documentElement.style.setProperty(
      "--nav-height",
      `${nav.getBoundingClientRect().bottom}px`,
    );
  }
</script>
