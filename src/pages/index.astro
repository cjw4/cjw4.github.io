---
import BasicLayout from "../layouts/BasicLayout.astro";
---

<BasicLayout title="Home">
  <section class="hero scroll-container">
    <div class="hero-intro snap-section">
      <img src="/profile.jpeg" alt="Me" class="hero-photo" />
      <div class="hero-text">
        <h1>Christopher Walker</h1>
        <ul>
          <li><a href="/about#engineer">Engineer</a></li>
          <li><a href="/about#mountain-enthusiast">Mountain Enthusiast</a></li>
          <li><a href="/about#disc-golfer">Disc Golfer</a></li>
        </ul>
        <p class="hero-cities">Zürich &bull; Chur &bull; Sedrun</p>
      </div>
    </div>
    <div class="hero-actions snap-section">
      <a href="/projects" class="btn">Check Out Projects</a>
      <a href="/blog" class="btn btn-outline">Read Latest Blog</a>
    </div>
  </section>
</BasicLayout>

<style>
  .hero {
    font-family: inherit;
  }

  .scroll-container {
    scroll-snap-type: y mandatory;
    height: calc(100vh - var(--nav-height, 0px));
    overflow-y: scroll;
  }

  .snap-section {
    scroll-snap-align: start;
    height: calc(100vh - var(--nav-height, 0px));
    width: 100%;
  }

  .hero-intro {
    display: flex;
    flex-direction: row-reverse;
    align-items: center;
    justify-content: center;
    column-gap: 3rem;
    row-gap: 1rem;
    flex-wrap: wrap;
    align-content: center;
  }

  .hero-photo {
    width: 300px;
    height: 300px;
    border-radius: 50%;
  }

  @media (max-width: 600px) {
    .hero-photo {
      width: 220px;
      height: 220px;
    }
  }

  .hero-text h1 {
    margin: 0 0 0.4rem;
    font-size: 3.2rem;
    color: #333;
    font-weight: 400;
    text-align: center;
  }

  .hero-text ul {
    list-style: none;
    padding: 0;
    margin: 1.2rem 0;
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
    font-size: 1.5rem;
    font-weight: 300;
    color: #555;
    text-align: center;
  }

  .hero-text ul li {
    display: inline;
  }

  .hero-text ul li:not(:last-child)::after {
    content: " | ";
    margin-left: 0.5rem;
    margin-right: 0.5rem;
  }

  .hero-text ul li a {
    color: inherit;
    text-decoration: none;
  }

  .hero-text ul li a:hover {
    text-decoration: underline;
  }

  .hero-text h2 {
    margin: 1.2rem 0;
    font-size: 1.5rem;
    font-weight: 300;
    color: #555;
    text-align: center;
  }

  .hero-cities {
    margin: 1.2rem 0 0;
    font-size: 1.2rem;
    font-weight: 300;
    color: #777;
    letter-spacing: 0.05em;
    text-align: center;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
  }

  .btn {
    padding: 0.7em 1.6em;
    font-size: 1rem;
    font-family: inherit;
    font-weight: 500;
    border-radius: 8px;
    text-decoration: none;
    background-color: #378a9c;
    color: #fff;
    transition: background-color 0.2s;
  }

  .btn:hover {
    background-color: #2d7389;
  }

  .btn-outline {
    background-color: transparent;
    color: #378a9c;
    border: 2px solid #378a9c;
  }

  .btn-outline:hover {
    background-color: #378a9c;
    color: #fff;
  }
</style>

<script>
  const nav = document.querySelector("nav");
  if (nav) {
    document.documentElement.style.setProperty(
      "--nav-height",
      `${nav.getBoundingClientRect().bottom}px`,
    );
  }
</script>
